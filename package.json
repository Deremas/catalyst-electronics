{
  "name": "catalyst-electronics",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "set NEXT_DIST_DIR=.next-dev&& next dev -p 3000",
    "build": "set NEXT_DIST_DIR=.next&& next build",
    "start": "next start -p 3000",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate",
    "lint": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@tailwindcss/postcss": "^4.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.21",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.2"
  }
}
